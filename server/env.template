# 服务器端口（云服务会自动设置，本地开发使用3000）
PORT=3000

# MongoDB连接字符串
# 本地开发：mongodb://localhost:27017/campus_simulator
# 云端部署：使用MongoDB Atlas的连接字符串
MONGODB_URI=mongodb://localhost:27017/campus_simulator

# CORS设置（允许的前端域名）
# 本地开发：*
# 云端部署：你的前端网站域名，如 https://your-site.vercel.app
CORS_ORIGIN=*

# 环境变量（production 或 development）
NODE_ENV=development


